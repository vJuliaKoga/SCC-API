            "pluginVersion": "11.0.0",
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "editorMode": "code",
                    "expr": "sum by (check, condition, run_id, api, call_mode, scenario) (\n    last_over_time(\n        k6_checks_total[30d]\n    )\n)",
                    "format": "table",
                    "instant": true,
                    "legendFormat": "{{check}} {{condition}} {{run_id}} {{api}} {{call_mode}} {{scenario}}",
                    "range": false,
                    "refId": "A"
                }
            ],
            "title": "k6 checks raw",
            "transformations": [
                {
                    "id": "labelsToFields",
                    "options": {
                        "mode": "columns"
                    }
                },
                {
                    "id": "organize",
                    "options": {
                        "excludeByName": {
                            "Time": true,
                            "__name__": true,
                            "job": true
                        },
                        "indexByName": {
                            "Value": 0,
                            "check": 1,
                            "condition": 2,
                            "run_id": 3,
                            "api": 4,
                            "call_mode": 5,
                            "scenario": 6
                        },
                        "renameByName": {
                            "Value": "value"
                        }
                    }
                }
            ],
            "type": "table"
        }
    ],
